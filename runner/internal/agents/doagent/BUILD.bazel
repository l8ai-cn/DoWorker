load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "doagent",
    srcs = [
        "parser.go",
        "register.go",
        "transport.go",
        "transport_control.go",
        "transport_session.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/runner/internal/agents/doagent",
    visibility = ["//runner:__subpackages__"],
    deps = [
        "//runner/internal/acp",
        "//runner/internal/agentkit",
        "//runner/internal/logger",
        "//runner/internal/tokenusage",
        "@com_github_google_uuid//:uuid",
    ],
)

alias(
    name = "go_default_library",
    actual = ":doagent",
    visibility = ["//runner:__subpackages__"],
)

go_test(
    name = "doagent_test",
    srcs = [
        "parser_test.go",
        "register_test.go",
        "transport_test.go",
    ],
    data = glob(
        ["testdata/**"],
        allow_empty = True,
    ),
    embed = [":doagent"],
    deps = [
        "//runner/internal/acp",
        "//runner/internal/agentkit",
        "//runner/internal/agents/doagent/testsupport",
        "//runner/internal/tokenusage",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
