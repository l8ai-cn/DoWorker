###############################################################################
# Local Bazel overrides — copy to .bazelrc.local (gitignored).
#
#   cp .bazelrc.local.example .bazelrc.local
#
# Caps memory/CPU so Bazel (frontend next_dev, runner cross-compile) does not
# starve Cursor / Docker on a 16–32 GB machine.
###############################################################################

# Limit parallel actions — lower if you still see memory pressure.
build --jobs=2

# Cap RAM (MiB) and CPU cores Bazel may consume for local actions.
build --local_resources=memory=6144,cpu=4

# When not actively building, release the daemon:
#   bazel shutdown
