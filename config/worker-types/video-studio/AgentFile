AGENT video-studio-codex
EXECUTABLE video-studio-codex

MODE pty
MODE acp "app-server"

CONFIG approval_mode SELECT("untrusted", "on-request", "never") = "untrusted"

ENV OPENAI_API_KEY SECRET OPTIONAL
ENV CODEX_HOME = sandbox.root + "/video-studio-home"

PROMPT_POSITION append
MCP ON

arg "resume" "--last" when config.resume_enabled and mode != "acp"
arg "--ask-for-approval" config.approval_mode when config.approval_mode != "" and mode != "acp"

if mcp.enabled {
  file sandbox.root + "/video-studio-home/config.toml" codex_mcp_toml(mcp.servers)

  mkdir sandbox.work_dir + "/.codex"
  file sandbox.work_dir + "/.codex/mcp.json" json({ mcpServers: mcp.servers })
}

CAPABILITY resume cli
CAPABILITY permission acp
CAPABILITY usage live
CAPABILITY interrupt true
CAPABILITY streaming true
CAPABILITY model_family gpt
