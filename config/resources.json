{
  "schema": "dosuite.skill-resources.v1",
  "product": "DoSql",
  "projectId": "agentsmesh",
  "defaultDoopsTarget": {
    "name": "local-docker",
    "cluster": "local",
    "instance": "agentsmesh-main"
  },
  "environmentMap": {
    "dev": {
      "alias": [
        "local",
        "docker",
        "agentsmesh-main"
      ],
      "doopsTarget": "local-docker",
      "note": "Local Docker development environment only."
    }
  },
  "resources": [
    {
      "id": "db_agentsmesh_dev_postgres",
      "name": "agentsmesh-dev-postgres",
      "kind": "PostgreSQL",
