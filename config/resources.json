{
  "schema": "dosuite.skill-resources.v1",
  "product": "DoSql",
  "projectId": "agentcloud",
  "defaultDoopsTarget": {
    "name": "local-docker",
    "cluster": "local",
    "instance": "agentcloud-main"
  },
  "environmentMap": {
    "dev": {
      "alias": [
        "local",
        "docker",
        "agentcloud-main"
      ],
      "doopsTarget": "local-docker",
      "note": "Local Docker development environment only."
    }
  },
  "resources": [
    {
      "id": "db_agentcloud_dev_postgres",
      "name": "agentcloud-dev-postgres",
      "kind": "PostgreSQL",
      "environmentId": "dev",
      "logicalEndpoint": "postgresql://postgres/agentcloud",
      "host": "postgres",
      "port": 5432,
      "databaseName": "agentcloud",
      "doopsTarget": "local-docker",
      "connectionRef": "docker-compose://deploy/dev/postgres#db=agentcloud",
      "secretRef": "container-env://postgres#POSTGRES_PASSWORD",
      "owner": "agentcloud",
      "status": "registered",
      "risk": "development",
      "tags": [
        "agentcloud",
        "dev",
        "docker",
        "postgres"
      ],
      "aliases": [
        "agentcloud postgres",
        "agentcloud dev db",
        "local agentcloud"
      ],
      "note": "Local PostgreSQL for Agent Cloud development. Mutations require a DoSQL journal and post-change verification.",
      "registeredAssetId": "db_agentcloud_dev_postgres",
      "displayName": "Agent Cloud Dev PostgreSQL"
    }
  ]
}
