# =============================================================================
# AgentsMesh Self-Hosted Configuration
# =============================================================================
#
# Copy this file to .env and edit the values, or use the install script:
#   ./scripts/install.sh --host 192.168.1.100
#
# =============================================================================

# =============================================================================
# Server Configuration (Required)
# =============================================================================
# Your server IP address or domain name (no protocol, no port)
# Examples: 192.168.1.100, agentsmesh.example.com
SERVER_HOST=__SERVER_HOST__

# Your server domain with port (if port is not specified, use 80 for http and 443 for https)
# Examples: 192.168.1.100:8080, agentsmesh.example.com:8080
PRIMARY_DOMAIN=_PRIMARY_DOMAIN_
PUBLIC_WEB_URL=http://_PRIMARY_DOMAIN_
PREVIEW_PUBLIC_ORIGIN=http://preview.example.com
PREVIEW_HOST=preview.example.com
PREVIEW_HOST_REGEX=preview\.example\.com
PREVIEW_COOKIE_MODE=same-site

# Optional mobile Worker entry. Leave empty until a separately deployed mobile
# service is reachable at this exact public origin.
MOBILE_PUBLIC_BASE_URL=

# When MOBILE_PUBLIC_BASE_URL is set, allow both Web origins to open Relay
# WebSockets. Use exact comma-separated origins.
# RELAY_ALLOWED_ORIGINS=http://_PRIMARY_DOMAIN_,https://mobile.example.com

# HTTP Port (default: 80)
HTTP_PORT=80

# gRPC Port for Runner mTLS connections (default: 9443)
GRPC_PORT=9443

# =============================================================================
# Image Version
# =============================================================================
# Docker Hub image tag. Use "latest" or a specific version like "sha-abc1234"
# See: https://hub.docker.com/u/agentsmesh
VERSION=latest

# =============================================================================
# Docker Compose Project Name
# =============================================================================
COMPOSE_PROJECT_NAME=agentsmesh

# =============================================================================
# Secrets (auto-generated by install.sh)
# =============================================================================
# PostgreSQL password
DB_PASSWORD=__CHANGE_ME__

# JWT secret for authentication
JWT_SECRET=__CHANGE_ME__

# Internal API secret for service-to-service communication
INTERNAL_API_SECRET=__CHANGE_ME__

# MinIO root password
MINIO_ROOT_PASSWORD=__CHANGE_ME__

# =============================================================================
# Optional: Service Ports
# =============================================================================
# MinIO Console port (for object storage management UI)
MINIO_CONSOLE_PORT=9001

# MinIO API port (internal, used by backend)
MINIO_API_PORT=9000

# =============================================================================
# Analytics (Optional)
# =============================================================================
# PostHog analytics - leave empty to disable tracking
# POSTHOG_KEY=
# POSTHOG_HOST=

# =============================================================================
# Email (Optional)
# =============================================================================
# Email provider: console (log to stdout), smtp (send real emails)
EMAIL_PROVIDER=console

# SMTP settings (uncomment if EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
