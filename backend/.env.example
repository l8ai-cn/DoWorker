# =============================================================================
# Agent Cloud Backend Configuration
# =============================================================================

# =============================================================================
# Unified Domain Configuration - Single Source of Truth
# All URLs (OAuth callbacks, webhooks, Relay, etc.) are derived from these
# =============================================================================
PRIMARY_DOMAIN=localhost:10000
PUBLIC_WEB_URL=http://localhost:10007
MOBILE_PUBLIC_BASE_URL=http://localhost:10021
PREVIEW_PUBLIC_ORIGIN=http://preview.localhost:10000
USE_HTTPS=false

# Server
SERVER_ADDRESS=:8080
DEBUG=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=agentcloud
DB_PASSWORD=agentcloud_dev
DB_NAME=agentcloud
DB_SSLMODE=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_PRIVATE_KEY_FILE=/run/secrets/access-token-private.pem
ACCESS_TOKEN_PUBLIC_KEY_FILE=/run/secrets/access-token-public.pem
ACCESS_TOKEN_KEY_ID=core-2026-01
ACCESS_TOKEN_ISSUER=http://localhost:10000
ACCESS_TOKEN_AUDIENCES=agentcloud-api,agentsmesh-api,marketplace-api
ACCESS_TOKEN_CORE_AUDIENCE=agentcloud-api
ACCESS_TOKEN_EXPIRATION_HOURS=24

# =============================================================================
# OAuth Configuration
# Only ClientID and ClientSecret are needed - RedirectURLs are derived from PRIMARY_DOMAIN
# Example: GitHub RedirectURL = https://{PRIMARY_DOMAIN}/api/v1/auth/oauth/github/callback
# =============================================================================

# OAuth - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitLab
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# OAuth - Gitee
GITEE_CLIENT_ID=
GITEE_CLIENT_SECRET=

# =============================================================================
# Payment Configuration
# NotifyURLs and ReturnURLs are derived from PRIMARY_DOMAIN
# =============================================================================

# Deployment Type: global | cn | onpremise
# - global: International users, use Stripe
# - cn: China users, use Alipay + WeChat Pay
# - onpremise: Self-hosted, use license file
DEPLOYMENT_TYPE=global

# Stripe (for DEPLOYMENT_TYPE=global)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Alipay (for DEPLOYMENT_TYPE=cn)
# NotifyURL derived: https://{PRIMARY_DOMAIN}/api/v1/webhooks/alipay
# ReturnURL derived: https://{PRIMARY_DOMAIN}/billing/callback
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_SANDBOX=false

# WeChat Pay (for DEPLOYMENT_TYPE=cn)
# NotifyURL derived: https://{PRIMARY_DOMAIN}/api/v1/webhooks/wechat
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_APIV3_KEY=
WECHAT_CERT_PATH=
WECHAT_KEY_PATH=
WECHAT_SANDBOX=false

# License (for DEPLOYMENT_TYPE=onpremise)
LICENSE_PUBLIC_KEY_PATH=
LICENSE_FILE_PATH=
LICENSE_SERVER_URL=

# =============================================================================
# Storage (S3-compatible: AWS S3 / MinIO / Aliyun OSS)
# =============================================================================

# For MinIO (development):
STORAGE_ENDPOINT=localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=agentcloud
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_USE_SSL=false
STORAGE_USE_PATH_STYLE=true

# For AWS S3 (production):
# STORAGE_ENDPOINT=              # Leave empty for AWS default
# STORAGE_REGION=us-west-2
# STORAGE_BUCKET=agentcloud-prod
# STORAGE_ACCESS_KEY=your-access-key
# STORAGE_SECRET_KEY=your-secret-key
# STORAGE_USE_SSL=true
# STORAGE_USE_PATH_STYLE=false

# For Aliyun OSS (S3-compatible mode):
# STORAGE_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# STORAGE_REGION=oss-cn-hangzhou
# STORAGE_BUCKET=agentcloud
# STORAGE_ACCESS_KEY=your-access-key
# STORAGE_SECRET_KEY=your-secret-key
# STORAGE_USE_SSL=true
# STORAGE_USE_PATH_STYLE=false

# Storage limits
STORAGE_MAX_FILE_SIZE=10
STORAGE_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4,application/pdf,application/json,application/xml,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain,text/markdown,text/csv,text/xml
