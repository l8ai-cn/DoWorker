load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "automation",
    srcs = [
        "adapter.go",
        "claude.go",
        "codex.go",
        "gemini.go",
        "loopal.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/service/agent/automation",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//backend/internal/domain/agent",
        "//backend/internal/domain/agentpod",
    ],
)

alias(
    name = "go_default_library",
    actual = ":automation",
    visibility = ["//backend:__subpackages__"],
)

go_test(
    name = "automation_test",
    srcs = ["adapter_test.go"],
    embed = [":automation"],
    deps = [
        "//backend/internal/domain/agentpod",
        "@com_github_stretchr_testify//assert",
    ],
)
