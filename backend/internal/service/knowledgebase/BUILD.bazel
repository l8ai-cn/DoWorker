load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "knowledgebase",
    srcs = [
        "contents.go",
        "mounts.go",
        "provisioner.go",
        "search.go",
        "service.go",
        "source_secrets.go",
        "sync.go",
        "sync_worker.go",
    ],
    embedsrcs = [
        "scaffold/AGENTS.md.tmpl",
        "scaffold/llms.txt.tmpl",
        "scaffold/raw-readme.md.tmpl",
        "scaffold/wiki-index.md.tmpl",
        "scaffold/wiki-log.md.tmpl",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/service/knowledgebase",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//backend/internal/domain/knowledgebase",
        "//backend/internal/infra/gitea",
        "//backend/internal/service/knowledgebase/connector",
        "//backend/pkg/crypto",
        "//backend/pkg/slugkit",
    ],
)

alias(
    name = "go_default_library",
    actual = ":knowledgebase",
    visibility = ["//backend:__subpackages__"],
)

go_test(
    name = "knowledgebase_test",
    srcs = [
        "provisioner_test.go",
        "source_secrets_test.go",
        "sync_test.go",
    ],
    embed = [":knowledgebase"],
    deps = [
        "//backend/internal/domain/knowledgebase",
        "//backend/internal/infra/gitea",
        "//backend/internal/service/knowledgebase/connector",
        "//backend/pkg/crypto",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
