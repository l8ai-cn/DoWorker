load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "agentsession",
    srcs = [
        "service.go",
        "service_lifecycle.go",
        "service_query.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/service/agentsession",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//backend/internal/domain/agentsession",
        "@io_gorm_gorm//:gorm",
    ],
)

go_test(
    name = "agentsession_test",
    srcs = ["service_test.go"],
    deps = [
        ":agentsession",
        "//backend/internal/domain/agentsession",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@io_gorm_driver_sqlite//:sqlite",
        "@io_gorm_gorm//:gorm",
    ],
)

alias(
    name = "go_default_library",
    actual = ":agentsession",
    visibility = ["//backend:__subpackages__"],
)
