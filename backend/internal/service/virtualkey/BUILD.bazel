load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "virtualkey",
    srcs = [
        "service.go",
        "token.go",
    ],
    importpath = "github.com/anthropics/agentsmesh/backend/internal/service/virtualkey",
    visibility = ["//backend:__subpackages__"],
    deps = [
        "//backend/internal/domain/virtualkey",
        "//backend/internal/service/aimodel",
    ],
)

alias(
    name = "go_default_library",
    actual = ":virtualkey",
    visibility = ["//backend:__subpackages__"],
)

go_test(
    name = "virtualkey_test",
    srcs = [
        "service_create_test.go",
        "service_resolve_scope_test.go",
        "service_test_support_test.go",
        "token_test.go",
    ],
    embed = [":virtualkey"],
    deps = [
        "//backend/internal/domain/aimodel",
        "//backend/internal/domain/virtualkey",
        "//backend/internal/service/aimodel",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
