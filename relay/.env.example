# =============================================================================
# AgentsMesh Relay 环境变量配置
# =============================================================================

# =============================================================================
# Unified Domain Configuration - Single Source of Truth
# RELAY_URL 自动从这两个变量派生（与 Backend/Web/Web-Admin 统一）
# =============================================================================

# 主域名 (e.g., "localhost:10000" 或 "agentsmesh.ai")
PRIMARY_DOMAIN=localhost:10000
PREVIEW_PUBLIC_ORIGIN=http://preview.localhost:10000

# 是否使用 HTTPS (true/false)
# 如果为 true，RELAY_URL 将使用 wss:// 协议
USE_HTTPS=false

# =============================================================================
# Required Secrets
# =============================================================================

# JWT Secret (必须与 Backend 保持一致)
JWT_SECRET=change-me-in-production

# Internal API Secret (用于 Relay <-> Backend 内部通信认证)
INTERNAL_API_SECRET=change-me-in-production

# =============================================================================
# Relay Identity
# =============================================================================

# Relay ID (默认自动生成)
# RELAY_ID=relay-1

# Relay 区域 (用于多区域部署)
RELAY_REGION=local

# =============================================================================
# Server Configuration (可选)
# =============================================================================

# 服务监听地址
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8090

# =============================================================================
# Backend Configuration (可选)
# =============================================================================

# Backend 内部 URL (Docker 环境)
# BACKEND_URL=http://backend:8080

# =============================================================================
# 传统配置方式（向后兼容，优先级高于 PRIMARY_DOMAIN）
# =============================================================================

# 显式指定 Relay 公开 URL (通常不需要，会从 PRIMARY_DOMAIN 派生)
# RELAY_URL=ws://localhost:10000/relay
