{
  "kind": "RecursiveLoopOrchestration",
  "schema_version": "2.0",
  "metadata": {
    "id": "definition-driven-worker-create-contract",
    "name": "Definition Driven Worker Create Contract",
    "description": "Implement and verify the Definition-owned Worker creation contract without fallback paths.",
    "locale": "en"
  },
  "objective": {
    "user_goal": "Create many Worker types through Definition-specific adapters, credentials, model resources, and configuration documents, then verify the real product path.",
    "business_value": "Prevent Worker forms and runtime materialization from drifting away from the formal Definition.",
    "done_definition": "Named configuration bindings, compatible resource projection, Runner materialization, browser evidence, and authorized lifecycle evidence pass without inferred support claims.",
    "non_goals": [
      "Do not use provider credentials without named non-production authorization.",
      "Do not preserve positional config bundle reads as a compatibility path.",
      "Do not publish, push, merge, or deploy automatically."
    ]
  },
  "clarification_policy": {
    "ambiguity_triggers": [
      "public protobuf or migration contract lacks approval",
      "provider credential authorization is absent",
      "browser capability is unavailable"
    ],
    "default_action": "ask_user",
    "secondary_user_query": {
      "prompt": "Approve named Definition configuration-document bindings as the replacement for positional config bundle IDs?",
      "required_when": [
        "the contract gate is reached",
        "a real credential or provider action is required"
      ],
      "max_questions": 1
    },
    "assumption_policy": {
      "allowed": "Only evidence ordering, test isolation, and read-only source analysis may be assumed.",
      "record_path": "PROGRESS.md"
    },
    "block_if": [
      "a public API contract or database migration has no approval",
      "a provider request would require a real credential"
    ]
  },
  "decomposition_policy": {
    "strategy": "definition_contract_then_per_worker_release_evidence",
    "split_until": [
      "each task has one owner",
      "each task has deterministic evidence",
      "each Worker lifecycle has its own evidence record"
    ],
    "minimum_task_granularity": "one contract slice, one verifier, or one Worker lifecycle",
    "max_depth": 4,
    "dependency_policy": "No implementation task may pass the approval gate or weaken an existing verifier."
  },
  "agents": [
    {
      "id": "orchestrator",
      "role": "orchestrator",
      "model_class": "strong_reasoning",
      "responsibilities": [
        "maintain state",
        "enforce gates",
        "integrate verified changes"
      ],
      "context_scope": "shared",
      "may_modify": [
        "PROGRESS.md",
        "state.json",
        "tasks.json",
        "evidence/"
      ]
    },
    {
      "id": "worker",
      "role": "worker",
      "model_class": "fast_worker",
      "responsibilities": [
        "implement one isolated contract slice",
        "run focused checks"
      ],
      "context_scope": "task_private",
      "may_modify": [
        "source files",
        "tests",
        "evidence/"
      ]
    },
    {
      "id": "reviewer",
      "role": "reviewer",
      "model_class": "strong_reasoning",
      "responsibilities": [
        "reject incomplete evidence",
        "review migration and API boundaries"
      ],
      "context_scope": "review_private",
      "may_modify": [
        "ACCEPTANCE.md",
        "evidence/"
      ]
    },
    {
      "id": "decision-proxy",
      "role": "decision_proxy",
      "model_class": "strong_reasoning",
      "responsibilities": [
        "choose low-risk evidence sequencing",
        "record blocked states"
      ],
      "context_scope": "shared",
      "may_modify": [
        "DECISIONS.md",
        "PROGRESS.md",
        "state.json"
      ]
    },
    {
      "id": "loop-supervisor",
      "role": "supervisor",
      "model_class": "strong_reasoning",
      "responsibilities": [
        "monitor drift",
        "enforce no-progress exits",
        "escalate gates"
      ],
      "context_scope": "shared",
      "may_modify": [
        "monitoring-plan.json",
        "PROGRESS.md"
      ]
    }
  ],
  "collaboration_policy": {
    "patterns": [
      "orchestrator_workers",
      "evaluator_optimizer",
      "independent_reviewer"
    ],
    "subagent_activation": {
      "allowed_when": [
        "read-only audits are independent",
        "review needs fresh context",
        "write paths do not overlap"
      ],
      "disallowed_when": [
        "a public contract decision is pending",
        "two agents would edit the same API or migration"
      ],
      "token_budget_policy": "Subagents return commands, exit codes, changed paths, evidence paths, and unresolved questions under 2000 tokens."
    },
    "handoff_contract": {
      "required_fields": [
        "task_id",
        "context_pack",
        "expected_output",
        "verification_refs"
      ],
      "return_fields": [
        "status",
        "artifacts",
        "evidence",
        "open_questions"
      ]
    }
  },
  "context_policy": {
    "max_context_tokens": 60000,
    "required_context_pack": [
      "loop.json",
      "state.json",
      "PROGRESS.md",
      "ACCEPTANCE.md",
      "DECISIONS.md"
    ],
    "retrieval_strategy": "just_in_time",
    "tool_output_trimming": "Keep commands, exit codes, assertions, changed paths, and evidence references; exclude secret values and raw provider output.",
    "compaction": {
      "trigger_ratio": 0.8,
      "summary_contract": "Preserve approved contract decisions, task state, verifier results, blockers, and lifecycle evidence."
    },
    "durable_memory": {
      "state_path": "state.json",
      "journal_path": "journal.jsonl",
      "progress_path": "PROGRESS.md"
    },
    "excluded_context": [
      "plaintext credentials",
      "access tokens",
      "raw provider responses",
      "unrelated logs"
    ]
  },
  "termination_policy": {
    "success": [
      "all acceptance items are checked",
      "independent review evidence exists"
    ],
    "failure": [
      "a protected verifier would need weakening",
      "the named binding contract is rejected",
      "a required upstream artifact cannot be obtained"
    ],
    "budget_exits": {
      "max_iterations": 20,
      "wall_clock_minutes": 360,
      "max_tokens": 360000
    },
    "no_progress": {
      "fingerprint_fields": [
        "active_task_id",
        "changed_paths",
        "verifier_id",
        "verifier_exit_code",
        "blocker_code"
      ],
      "max_stale_iterations": 2
    },
    "human_gate": [
      "before protobuf or database migration changes",
      "before provider credential use",
      "before browser mutation, push, merge, publish, or deploy"
    ]
  },
  "verification_policy": {
    "verifiers": [
      {
        "id": "contract-baseline",
        "command": "bash scripts/verify-contract-baseline.sh",
        "expected_result": "exit code 0",
        "scope": "per_task"
      },
      {
        "id": "approval-gate",
        "command": "bash scripts/verify-contract-approval.sh",
        "expected_result": "exit code 0 only after the human decision is recorded",
        "scope": "per_task"
      },
      {
        "id": "focused-contract-tests",
        "command": "bash scripts/verify-focused-contract-tests.sh",
        "expected_result": "exit code 0",
        "scope": "per_task"
      }
    ],
    "protected_paths": [
      "loop.json",
      "scripts/verify.sh",
      "scripts/verify-contract-baseline.sh",
      "scripts/verify-contract-approval.sh",
      "scripts/verify-focused-contract-tests.sh",
      "tests",
      ".github/workflows"
    ],
    "anti_gaming_rules": [
      "do not delete tests",
      "do not weaken verifier commands",
      "do not add continue-on-error",
      "do not change support state without evidence"
    ]
  },
  "cost_policy": {
    "optimization_goal": "Maximize verified product evidence while stopping at public-contract and credential gates.",
    "token_budget_by_agent": {
      "orchestrator": 120000,
      "worker": 140000,
      "reviewer": 60000,
      "decision-proxy": 20000,
      "loop-supervisor": 20000
    },
    "stop_when_marginal_value_low": true
  },
  "decision_policy": {
    "blocked_state_path": "DECISIONS.md",
    "decision_log_path": "journal.jsonl",
    "user_confirmation": {
      "required_before_delegation": true,
      "prompt": "May the decision-proxy choose only low-risk evidence order and one read-only verifier retry?",
      "confirmation_record_path": "PROGRESS.md"
    },
    "proxy_decision_agent": {
      "agent_id": "decision-proxy",
      "decision_authority": "delegated_low_risk",
      "allowed_decisions": [
        "choose evidence order",
        "split a read-only audit",
        "retry one deterministic verifier"
      ],
      "forbidden_decisions": [
        "irreversible action",
        "public contract approval",
        "credential use",
        "production deploy"
      ],
      "default_when_uncertain": "ask_user",
      "decision_record_fields": [
        "blocked_reason",
        "options",
        "selected_option",
        "rationale",
        "evidence_ref"
      ]
    },
    "supervisor_agent": {
      "agent_id": "loop-supervisor",
      "review_cadence_iterations": 2,
      "drift_checks": [
        "active task maps to the objective",
        "public contract changes have approval",
        "verifiers remain protected"
      ],
      "intervention_actions": [
        "pause invalid progress",
        "record no-progress exit",
        "escalate to user"
      ],
      "report_path": "monitoring-plan.json"
    },
    "blocked_handling": {
      "blocked_signals": [
        "approval missing",
        "credential authorization missing",
        "same verifier fails twice",
        "browser capability unavailable"
      ],
      "max_blocked_cycles": 1,
      "allowed_resolution_actions": [
        "record durable evidence",
        "ask the secondary user query",
        "process an independent read-only audit"
      ],
      "escalation_required_when": [
        "public API decision",
        "database migration decision",
        "provider action",
        "protected verifier conflict"
      ]
    }
  },
  "risk_policy": {
    "risk_levels": [
      "low",
      "medium",
      "high",
      "critical"
    ],
    "high_risk_requires_human": [
      "security",
      "public API",
      "database migration",
      "provider credential",
      "deployment"
    ],
    "forbidden_behaviors": [
      "silent fallback",
      "weakening validation",
      "storing plaintext secrets",
      "inferred Worker support"
    ]
  },
  "execution_adapters": [
    {
      "target": "codex",
      "instruction_files": [
        "AGENTS.md"
      ],
      "supports_subagents": true,
      "subagent_activation": "explicit_request",
      "deterministic_hooks": "not_assumed",
      "approval_model": "sandbox_and_policy",
      "context_reload_model": "session_instruction_discovery",
      "generated_files": [
        "AGENTS.md"
      ],
      "unsupported_capability_behavior": "block_and_report"
    },
    {
      "target": "claude_code",
      "instruction_files": [
        "CLAUDE.md"
      ],
      "supports_subagents": true,
      "subagent_activation": "description_or_explicit_agent",
      "deterministic_hooks": "supported",
      "approval_model": "permissions_and_hooks",
      "context_reload_model": "CLAUDE.md_and_memory",
      "generated_files": [
        "CLAUDE.md",
        ".claude/settings.json"
      ],
      "unsupported_capability_behavior": "block_and_report"
    },
    {
      "target": "cursor",
      "instruction_files": [
        ".cursor/rules/looper-creator.mdc"
      ],
      "supports_subagents": true,
      "subagent_activation": "cursor_subagents_or_cloud_agents",
      "deterministic_hooks": "supported_when_configured",
      "approval_model": "cursor_agent_security",
      "context_reload_model": "rules_skills_mentions",
      "generated_files": [
        ".cursor/rules/looper-creator.mdc"
      ],
      "unsupported_capability_behavior": "block_and_report"
    }
  ],
  "portability_policy": {
    "adapter_outputs_are_generated": true,
    "canonical_manifest": "loop.json",
    "do_not_weaken_verification_for_platform_limits": true,
    "platform_selection_query": "Which supported runtime should execute this contract loop?",
    "unsupported_capability_behavior": "block_and_report"
  },
  "failure_modes": [
    {
      "id": "approval-bypass",
      "mitigation": "Block source changes that alter the public contract until a human decision is recorded."
    },
    {
      "id": "evidence-overclaim",
      "mitigation": "Require image, Runner, browser, lifecycle, and cleanup evidence before support promotion."
    },
    {
      "id": "context-drift",
      "mitigation": "Reload durable state and compact evidence summaries each cycle."
    }
  ],
  "templates": [
    "feature-development",
    "testing-debugging",
    "website-browser-testing"
  ],
  "acceptance_checklist": {
    "path": "ACCEPTANCE.md",
    "update_policy": "Mark an item only after its verifier and durable evidence pass; a rejected or blocked gate remains unchecked.",
    "items": [
      {
        "id": "accept-current-contract-baseline",
        "task_id": "current-contract-baseline",
        "description": "Record the authoritative current Worker create boundary and evidence state.",
        "owner_agent": "reviewer",
        "acceptance_criteria": [
          "baseline verifier exits 0",
          "no Worker support claim changes"
        ],
        "verification_refs": [
          "contract-baseline"
        ],
        "evidence_refs": [
          "evidence/current-contract-baseline.json"
        ]
      },
      {
        "id": "accept-named-binding-approval",
        "task_id": "named-binding-approval",
        "description": "Obtain the public-contract decision for named configuration documents.",
        "owner_agent": "orchestrator",
        "acceptance_criteria": [
          "human decision is recorded",
          "approval verifier exits 0"
        ],
        "verification_refs": [
          "approval-gate"
        ],
        "evidence_refs": [
          "evidence/named-binding-approval.json"
        ]
      },
      {
        "id": "accept-named-binding-implementation",
        "task_id": "named-binding-implementation",
        "description": "Replace positional configuration bundle references with named Definition bindings.",
        "owner_agent": "worker",
        "acceptance_criteria": [
          "focused contract tests exit 0",
          "unknown, duplicate, wrong-kind, and malformed bindings fail"
        ],
        "verification_refs": [
          "focused-contract-tests"
        ],
        "evidence_refs": [
          "evidence/named-binding-implementation.json"
        ]
      },
      {
        "id": "accept-resource-projection",
        "task_id": "resource-projection",
        "description": "Return only Definition-compatible model and credential references to the form.",
        "owner_agent": "worker",
        "acceptance_criteria": [
          "focused contract tests exit 0",
          "projection contains no secret values"
        ],
        "verification_refs": [
          "focused-contract-tests"
        ],
        "evidence_refs": [
          "evidence/resource-projection.json"
        ]
      },
      {
        "id": "accept-definition-driven-web",
        "task_id": "definition-driven-web",
        "description": "Render named documents and server-filtered resources without static Worker mappings.",
        "owner_agent": "worker",
        "acceptance_criteria": [
          "focused contract tests exit 0",
          "stale draft references reset on Worker type change"
        ],
        "verification_refs": [
          "focused-contract-tests"
        ],
        "evidence_refs": [
          "evidence/definition-driven-web.json"
        ]
      },
      {
        "id": "accept-runner-materialization",
        "task_id": "runner-materialization",
        "description": "Migrate snapshots and materialize Definition-owned document targets at Runner.",
        "owner_agent": "worker",
        "acceptance_criteria": [
          "focused contract tests exit 0",
          "Runner writes only resolved Definition targets"
        ],
        "verification_refs": [
          "focused-contract-tests"
        ],
        "evidence_refs": [
          "evidence/runner-materialization.json"
        ]
      },
      {
        "id": "accept-real-worker-release",
        "task_id": "real-worker-release",
        "description": "Record authorized lifecycle, cleanup, and browser evidence for each eligible Worker.",
        "owner_agent": "reviewer",
        "acceptance_criteria": [
          "real lifecycle evidence is recorded",
          "every promoted Worker has cleanup evidence"
        ],
        "verification_refs": [],
        "evidence_refs": [
          "evidence/real-worker-release.json"
        ]
      }
    ]
  },
  "state": {
    "path": "state.json",
    "journal_path": "journal.jsonl",
    "progress_path": "PROGRESS.md"
  },
  "observability": {
    "trace_fields": [
      "loop_node_id",
      "task_id",
      "verifier_id",
      "verifier_exit_code",
      "blocker_code",
      "changed_paths"
    ],
    "evidence_dir": "evidence"
  },
  "human_gates": {
    "irreversible_actions": [
      "approve public contract change",
      "run database migration",
      "use provider credentials",
      "create non-test Worker",
      "push, merge, publish, or deploy"
    ],
    "approval_record_path": "PROGRESS.md"
  },
  "escalation": {
    "condition": "approval, credential, browser, budget, or no-progress gate is reached",
    "owner": "Agent Cloud maintainer",
    "channel": "Codex thread",
    "message_template": "Definition-driven Worker loop stopped: {reason}. Evidence: {evidence_ref}."
  },
  "loop_nodes": [
    {
      "id": "root",
      "type": "agent_loop",
      "purpose": "Run the goal-based contract loop and stop at irreversible or unverified boundaries.",
      "entry_conditions": [
        "state is planned or running",
        "durable state is loaded"
      ],
      "exit_conditions": [
        "all acceptance items pass",
        "human gate required",
        "budget or no-progress exit"
      ],
      "steps": [
        "reload state",
        "select eligible task",
        "run verifier",
        "record evidence",
        "supervisor review"
      ],
      "context_pack": [
        "loop.json",
        "state.json",
        "PROGRESS.md",
        "ACCEPTANCE.md",
        "DECISIONS.md"
      ],
      "agent_assignments": [
        "orchestrator",
        "loop-supervisor"
      ],
      "verification_refs": [
        "contract-baseline"
      ],
      "children": [
        {
          "id": "contract-cycle",
          "type": "evaluator_optimizer_loop",
          "purpose": "Implement one approved contract slice and verify it before another slice begins.",
          "entry_conditions": [
            "named binding approval is accepted",
            "one implementation task is eligible"
          ],
          "exit_conditions": [
            "task accepted",
            "focused verifier fails twice",
            "human gate reached"
          ],
          "steps": [
            "write failing test",
            "implement minimum change",
            "run focused verifier",
            "review evidence"
          ],
          "context_pack": [
            "approved decision",
            "selected Definition",
            "affected API and form files",
            "verifier output"
          ],
          "agent_assignments": [
            "worker",
            "reviewer"
          ],
          "verification_refs": [
            "focused-contract-tests"
          ]
        },
        {
          "id": "release-review",
          "type": "human_review_gate",
          "purpose": "Require explicit authorization before provider-backed lifecycle and browser evidence.",
          "entry_conditions": [
            "contract implementation is accepted",
            "eligible non-production resource is named"
          ],
          "exit_conditions": [
            "authorization recorded",
            "authorization denied",
            "resource unavailable"
          ],
          "steps": [
            "confirm named resource",
            "run disposable lifecycle",
            "verify cleanup",
            "record browser evidence"
          ],
          "context_pack": [
            "release evidence",
            "cleanup evidence",
            "browser evidence"
          ],
          "agent_assignments": [
            "orchestrator",
            "reviewer"
          ],
          "verification_refs": []
        }
      ]
    }
  ],
  "atomic_tasks": [
    {
      "id": "current-contract-baseline",
      "goal": "Record the current typed and untyped Worker creation boundaries from source and real local evidence.",
      "input_refs": [
        "config/worker-types/",
        "backend/internal/service/workercreation/",
        "clients/web/src/",
        "runner/internal/"
      ],
      "output_artifacts": [
        "evidence/current-contract-baseline.json"
      ],
      "dependencies": [],
      "assigned_agent": "reviewer",
      "acceptance_criteria": [
        "baseline verifier exits 0",
        "no Worker support claim changes"
      ],
      "verification_refs": [
        "contract-baseline"
      ],
      "max_attempts": 2,
      "estimated_token_budget": 25000,
      "tools": [
        "shell",
        "apply_patch"
      ]
    },
    {
      "id": "named-binding-approval",
      "goal": "Obtain an explicit decision to replace positional configuration bundle IDs with named Definition bindings.",
      "input_refs": [
        "evidence/current-contract-baseline.json",
        "docs/superpowers/plans/2026-07-16-worker-definition-driven-create-contract.md"
      ],
      "output_artifacts": [
        "evidence/named-binding-approval.json"
      ],
      "dependencies": [
        "current-contract-baseline"
      ],
      "assigned_agent": "orchestrator",
      "acceptance_criteria": [
        "human decision is recorded",
        "approval verifier exits 0"
      ],
      "verification_refs": [
        "approval-gate"
      ],
      "max_attempts": 1,
      "estimated_token_budget": 10000,
      "tools": [
        "shell"
      ]
    },
    {
      "id": "named-binding-implementation",
      "goal": "Implement named configuration-document bindings throughout the canonical Worker create contract.",
      "input_refs": [
        "approved named binding decision",
        "proto/pod/v1/worker_creation.proto",
        "backend/internal/service/workercreation/"
      ],
      "output_artifacts": [
        "evidence/named-binding-implementation.json"
      ],
      "dependencies": [
        "named-binding-approval"
      ],
      "assigned_agent": "worker",
      "acceptance_criteria": [
        "focused contract tests exit 0",
        "unknown, duplicate, wrong-kind, and malformed bindings fail"
      ],
      "verification_refs": [
        "focused-contract-tests"
      ],
      "max_attempts": 3,
      "estimated_token_budget": 65000,
      "tools": [
        "shell",
        "apply_patch"
      ]
    },
    {
      "id": "resource-projection",
      "goal": "Project compatible model resources and typed credential references from the selected Definition.",
      "input_refs": [
        "backend/internal/service/workercreation/",
        "clients/core/",
        "clients/web/src/lib/api/"
      ],
      "output_artifacts": [
        "evidence/resource-projection.json"
      ],
      "dependencies": [
        "named-binding-implementation"
      ],
      "assigned_agent": "worker",
      "acceptance_criteria": [
        "focused contract tests exit 0",
        "projection contains no secret values"
      ],
      "verification_refs": [
        "focused-contract-tests"
      ],
      "max_attempts": 3,
      "estimated_token_budget": 50000,
      "tools": [
        "shell",
        "apply_patch"
      ]
    },
    {
      "id": "definition-driven-web",
      "goal": "Render Definition-declared documents and backend-filtered resources without static Worker compatibility maps.",
      "input_refs": [
        "clients/web/src/components/pod/",
        "clients/web/src/lib/api/",
        "clients/core/"
      ],
      "output_artifacts": [
        "evidence/definition-driven-web.json"
      ],
      "dependencies": [
        "resource-projection"
      ],
      "assigned_agent": "worker",
      "acceptance_criteria": [
        "focused contract tests exit 0",
        "stale draft references reset on Worker type change"
      ],
      "verification_refs": [
        "focused-contract-tests"
      ],
      "max_attempts": 3,
      "estimated_token_budget": 50000,
      "tools": [
        "shell",
        "apply_patch",
        "browser"
      ]
    },
    {
      "id": "runner-materialization",
      "goal": "Migrate Worker snapshots and preserve resolved Definition document targets into Runner materialization.",
      "input_refs": [
        "backend/migrations/",
        "backend/internal/service/agentpod/",
        "runner/internal/runner/"
      ],
      "output_artifacts": [
        "evidence/runner-materialization.json"
      ],
      "dependencies": [
        "definition-driven-web"
      ],
      "assigned_agent": "worker",
      "acceptance_criteria": [
        "focused contract tests exit 0",
        "Runner writes only resolved Definition targets"
      ],
      "verification_refs": [
