# === Identity ===
AGENT opencode
EXECUTABLE opencode

# === Mode ===
MODE pty
MODE acp "acp"

# === Configuration ===
CONFIG model STRING = ""

# === Environment ===
ENV OPENAI_API_KEY SECRET OPTIONAL

# === Prompt ===
PROMPT_POSITION prepend

# === Capabilities ===
MCP ON FORMAT opencode

# === Build Logic ===
file sandbox.work_dir + "/opencode.json" json({ model: config.model })

if mcp.enabled {
  file sandbox.work_dir + "/opencode.json" json({ model: config.model, mcp: mcp.servers })
}

CAPABILITY resume acp
CAPABILITY permission acp
CAPABILITY usage live
CAPABILITY interrupt true
CAPABILITY streaming false
CAPABILITY model_family multi
