{
  "name": "do-worker-workspace-root",
  "private": true,
  "description": "Workspace root. Frontend deps live here; first-party @do-worker/* and do-worker-wasm are pnpm workspace packages under packages/ and proto/.",
  "scripts": {
    "worker-docs:sync": "node scripts/generate-worker-docs-catalog.mjs",
    "worker-docs:check": "node scripts/generate-worker-docs-catalog.mjs --check",
    "worker-runtime:check": "node scripts/verify-managed-worker-runtime-config.mjs",
    "proto:gen-ts": "buf generate",
    "proto:gen-go": "bash scripts/proto-gen-go.sh",
    "proto:gen-amesh": "bash scripts/sync-amesh-convert.sh",
    "proto:gen-go-all": "bash scripts/proto-gen-go.sh --force && bash scripts/sync-amesh-convert.sh --force",
    "build:wasm": "bash scripts/build-wasm.sh",
    "web:lint": "cd clients/web && ../../node_modules/.bin/eslint --no-warn-ignored --no-error-on-unmatched-pattern .",
    "web:typecheck": "pnpm run worker-docs:check && pnpm run worker-runtime:check && pnpm exec tsc --noEmit -p clients/web/tsconfig.json",
    "web:test": "cd clients/web && VITEST=true NODE_OPTIONS='--experimental-require-module' ../../node_modules/.bin/vitest run --config vitest.config.ts --reporter=default --no-color",
    "web:dev": "cd clients/web && node ../../node_modules/next/dist/bin/next dev --turbopack",
    "web:build": "pnpm run worker-docs:check && cd clients/web && BAZEL_BUILD=standalone node ../../node_modules/next/dist/bin/next build --webpack",
    "web:check": "pnpm run web:lint && pnpm run web:typecheck && pnpm run web:test",
    "marketplace-web:lint": "cd clients/marketplace-web && ../../node_modules/.bin/eslint --no-warn-ignored --no-error-on-unmatched-pattern .",
    "marketplace-web:typecheck": "pnpm exec tsc --noEmit -p clients/marketplace-web/tsconfig.json",
    "marketplace-web:test": "cd clients/marketplace-web && ../../node_modules/.bin/vitest run --config vitest.config.ts --reporter=default --no-color",
    "marketplace-web:dev": "cd clients/marketplace-web && node ../../node_modules/next/dist/bin/next dev --turbopack",
    "marketplace-web:build": "cd clients/marketplace-web && BAZEL_BUILD=standalone node ../../node_modules/next/dist/bin/next build --webpack",
    "marketplace-web:check": "pnpm run marketplace-web:lint && pnpm run marketplace-web:typecheck && pnpm run marketplace-web:test",
    "mobile:dev": "bash scripts/start-mobile-dev.sh",
    "mobile:lint": "pnpm --filter @do-worker/mobile lint",
    "mobile:typecheck": "pnpm --filter @do-worker/mobile exec tsc --noEmit",
    "mobile:test": "pnpm --filter @do-worker/mobile test",
    "mobile:build": "pnpm --filter @do-worker/mobile build",
    "mobile:check": "pnpm run mobile:lint && pnpm run mobile:typecheck && pnpm run mobile:test",
    "web-admin:lint": "cd clients/web-admin && ../../node_modules/.bin/eslint --no-warn-ignored --no-error-on-unmatched-pattern .",
    "web-admin:typecheck": "pnpm exec tsc --noEmit -p clients/web-admin/tsconfig.json",
    "web-admin:test": "cd clients/web-admin && VITEST=true NODE_OPTIONS='--experimental-require-module' ../../node_modules/.bin/vitest run --config vitest.config.ts --reporter=default --no-color --passWithNoTests",
    "web-admin:dev": "cd clients/web-admin && node ../../node_modules/next/dist/bin/next dev --turbopack",
    "web-admin:build": "cd clients/web-admin && BAZEL_BUILD=standalone node ../../node_modules/next/dist/bin/next build --webpack",
    "web-admin:check": "pnpm run web-admin:lint && pnpm run web-admin:typecheck && pnpm run web-admin:test",
    "check:web": "pnpm run web:check && pnpm run web-admin:check"
  },
  "dependencies": {
    "@blocknote/core": "^0.47.3",
    "@blocknote/mantine": "^0.47.3",
    "@blocknote/react": "^0.47.3",
    "@bufbuild/protobuf": "^2.2.0",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@do-worker/agent-ui": "workspace:*",
    "@do-worker/proto": "workspace:*",
    "@do-worker/service-interface": "workspace:*",
    "@do-worker/service-runtime": "workspace:*",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.8",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@use-gesture/react": "^10.3.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.2",
    "blockly": "^12.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "date-fns": "^4.1.0",
    "do-worker-wasm": "workspace:*",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.45",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-intl": "^4.7.0",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.360.2",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.9.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "xterm": "^5.3.0",
    "yaml": "^2.8.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.45.0",
    "@bufbuild/protoc-gen-es": "^2.2.0",
    "@playwright/test": "1.50.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "4.0.18",
    "dotenv": "^16.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5",
    "vite": "^7",
    "vitest": "4.0.18"
  },
  "pnpm": {
    "overrides": {
      "@playwright/test": "1.50.1",
      "playwright": "1.50.1",
      "playwright-core": "1.50.1",
      "eslint-plugin-react-hooks": "7.0.1"
    },
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ],
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher"
    ]
  }
}
